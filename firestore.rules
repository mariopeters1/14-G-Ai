
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public write for contact form submissions
    match /contacts/{contactId} {
      allow create: if true;
      // Reading/updating/deleting contacts should be restricted to authenticated users (admins)
      allow read, update, delete: if request.auth != null; 
    }

    // Allow public write for cost savings leads from the calculator
    match /costSavingsLeads/{leadId} {
      allow create: if true;
      // Allow authenticated users (admins) to manage leads
      allow read, update, delete: if request.auth != null;
    }

    // Rules for AI Chef chat (admin-only)
    match /ai-chef-chat/main-chat/messages/{messageId} {
        allow read, create: if request.auth != null;
    }
    
    // Rules for AI Careers chat (public)
    match /ai-careers-chat/public-chat/messages/{messageId} {
        allow read, create: if true;
    }

    // Fallback rule to deny all other access to prevent unsecured collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
